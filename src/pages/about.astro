---
//import type { IFrontmatter } from 'astro-boilerplate-components';

import Base from '@/templates/Base.astro';
import { AppConfig } from '@/utils/AppConfig';

//const allPosts = await Astro.glob<IFrontmatter>('./posts/*.md');

const { title } = AppConfig;
const { description } = AppConfig;
---

<Base head={{ title, description }}>
 
    <section class="py-12 px-8 sm:px-12 bg-zinc-300 text-slate-950 shadow-2xl">
      <div class="text-center">
        <h1 class="text-3xl sm:text-4xl jura-header font-bold">About Briarwood Software</h1>
      </div>
      <div class="max-w-6xl py-6 mx-auto">
        <p class="sm:text-lg py-4">
          Briarwood Software builds custom websites, web applications, and integrations for businesses that need software tailored to how they actually work.
          Every project starts with understanding your business &mdash; your workflows, your pain points, your goals &mdash; before a single line of code is written.
        </p>
        <p class="sm:text-lg py-4">
          Our clients range from research initiatives at MIT to small businesses launching their first digital platforms.
          Whether you need a customer-facing website, an internal tool, or a system that connects the software you already use, we build it, host it, and keep it running.
        </p>
      </div>
      <div class="flex items-center justify-center gap-x-6">
        <a href="/contact/"
          class="rounded-md bg-emerald-600 px-6 py-4 text-lg lg:text-xl font-semibold text-white shadow-md hover:bg-sky-500 transition-all duration-300">
          Get in Touch
        </a>
      </div>
    </section>

    <section class="py-12 px-8 sm:px-12 shadow-2xl">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-center lg:text-left text-3xl sm:text-4xl font-semibold jura-header">About the Founder</h2>
        <div class="mt-6">

          <div class="lg:flex">
            <div class="lg:w-2/5 px-10 my-6 order-first lg:order-last flex items-center justify-center">
              <img
                src="/assets/images/lauren.jpg"
                alt="Lauren"
                class="img-shadow w-28 md:w-36 lg:w-48 rounded-full border-2 border-slate-800 object-cover"
              />
            </div>
            <div class="lg:w-4/5">
            <h3 class="text-lg sm:text-xl text-center sm:text-left font-medium">Hi, I'm Lauren - Full-Stack Engineer & Founder</h3>
            <p class="mt-4 sm:text-lg">
                I've spent over a decade building software professionally, everything from small internal tools to large-scale automation systems used in manufacturing.
                Along the way, I've learned that the hardest part of any project isn't the code. It's figuring out exactly which problems need to be solved, in which order, and how.
            </p>
            <p class="mt-4 sm:text-lg">
                That's what I do best, and it's why I started Briarwood Software. I work directly with business owners to understand what they need, then build practical, well-crafted software that fits.
                No jargon, no handoffs to other devs, no selling you something you don't need.
            </p>
          </div>
          </div>

            <h3 class="mt-8 text-lg sm:text-xl text-center font-semibold">How I Work</h3>
            <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-8 text-center">
              <div>
                <i class="fa-solid fa-magnifying-glass-chart text-3xl mb-4" style="color: rgb(63, 181, 188);"></i>
                <h4 class="text-lg font-semibold mt-2">Business First, Tech Second</h4>
                <p class="mt-2 text-zinc-300 sm:text-base">I start every project by understanding your operations, not pitching a technology stack. The right solution follows from the right questions.</p>
              </div>
              <div>
                <i class="fa-solid fa-user-check text-3xl mb-4" style="color: rgb(63, 181, 188);"></i>
                <h4 class="text-lg font-semibold mt-2">Senior-Level Work, Start to Finish</h4>
                <p class="mt-2 text-zinc-300 sm:text-base">From the first conversation through deployment and beyond, you're working with the same experienced engineer. Nothing gets outsourced.</p>
              </div>
              <div>
                <i class="fa-solid fa-shield-halved text-3xl mb-4" style="color: rgb(63, 181, 188);"></i>
                <h4 class="text-lg font-semibold mt-2">Built to Last</h4>
                <p class="mt-2 text-zinc-300 sm:text-base">I write clean, maintainable software and stick around to support it. When your business evolves, your software can evolve with it.</p>
              </div>
            </div>
        </div>
      </div>
    </section>

  </div>

</Base>
